{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenNotebookBridgeManifest",
  "type": "object",
  "required": [
    "export_id",
    "exported_at",
    "source_system",
    "notebook_title",
    "sources"
  ],
  "properties": {
    "export_id": {
      "type": "string",
      "minLength": 1
    },
    "exported_at": {
      "type": "string",
      "minLength": 1
    },
    "source_system": {
      "type": "string",
      "const": "open_notebook"
    },
    "notebook_title": {
      "type": "string",
      "minLength": 1
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "source_id",
          "title",
          "source_type",
          "exported_path",
          "content_sha256",
          "is_ai_generated",
          "citation_policy"
        ],
        "properties": {
          "source_id": {
            "type": "string",
            "pattern": "^onb:"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "source_type": {
            "type": "string",
            "minLength": 1
          },
          "original_url": {
            "type": [
              "string",
              "null"
            ]
          },
          "exported_path": {
            "type": "string",
            "minLength": 1
          },
          "content_sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "is_ai_generated": {
            "type": "boolean"
          },
          "citation_policy": {
            "type": "string",
            "enum": [
              "authoritative",
              "derived_non_authoritative"
            ]
          }
        }
      }
    }
  }
}