# Hugging Face Spaces — demo (Secrets или .env на Space)
# См. deploy/hf-spaces/README.md

OPENAI_API_BASE=https://openrouter.ai/api/v1
# OPENAI_API_KEY=<HF Settings → Secrets>
LLM_MODEL=meta-llama/llama-3.2-3b-instruct:free
EMBED_MODEL=perplexity/pplx-embed-v1-0.6b
EMBED_DIMENSIONS=1024

ENABLE_METADATA_ENRICHMENT=false
ENABLE_DOCUMENT_SUMMARIES=false
ENABLE_RERANKER=false

# Аутентификация (Workstream A) — включить на проде, своё значение JWT_SECRET (не дефолт).
AUTH_ENABLED=true
# JWT_SECRET=<HF Settings → Secrets>

# Аналитика (Workstream E) — опционально.
# YANDEX_METRIKA_ID=<HF Settings → Secrets>
