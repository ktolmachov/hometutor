# =============================================================================
# home_rag runtime configuration
# Non-secret runtime configuration (tracked in git).
# Machine-specific secrets (API keys) go in .env (gitignored).
#
# Updated: 2026-06-21
#
# Final local primary model for home_rag:
#   gemma-4-26b-a4b-it-q4-0 (llama.cpp smoke validation 2026-06-21)
#
# Selection criteria:
#   RAG Q&A, tutor, quiz, summaries, document analysis, anti-hallucination,
#   Russian language, stability and reasonable speed.
#
# Coding model selection is intentionally NOT encoded here:
#   the project author switches coding/Python models manually per task.
# =============================================================================


# =============================================================================
# Provider endpoints & primary local model
# =============================================================================

# OpenRouter-compatible cloud endpoint for fallback/evaluation roles.
OPENAI_API_BASE=https://openrouter.ai/api/v1

# OpenAI-compatible local server.
# Switch safely with -Profile llama-cpp or -Profile lm-studio (scripts/switch_local_llm.ps1).
# llama.cpp exposes an OpenAI-compatible API; keep the model id in sync with /v1/models.
LOCAL_LLM_PROFILE=llama-cpp
LLM_API_BASE=http://127.0.0.1:8080/v1

# Primary local model for home_rag.
LLM_MODEL=gemma-4-26b-a4b-it-q4-0

# Use the same balanced model for quiz/tutor-style local generation.
QUIZ_LLM_MODEL=gemma-4-26b-a4b-it-q4-0

# LlamaIndex sometimes validates token limits against an OpenAI model id.
# Keep this as a known cloud-compatible fallback id, not the local server model id.
LLAMAINDEX_METADATA_FALLBACK_MODEL=gpt-4o-mini

# Local graph/concept model.
# Used for graph-related tasks: concept extraction, prerequisite chains,
# learning graph summaries, course graph analysis and Smart Study Router support.
# Keep it local-first and aligned with the balanced home_rag model.
GRAPH_LLM_API_BASE=http://127.0.0.1:8080/v1
GRAPH_MODEL=gemma-4-26b-a4b-it-q4-0

# =============================================================================
# Secondary cloud/model roles
# =============================================================================
# These roles are NOT the default home_rag local model.
# They are used only where the application explicitly routes to them.

EVAL_JUDGE_LLM=openai/gpt-4o-mini
REWRITE_MODEL=openai/gpt-4o-mini
CLASSIFIER_MODEL=openai/gpt-4o-mini
INGESTION_MODEL=google/gemma-4-31b-it
EVALUATE_MODEL=openai/gpt-4o-mini


# =============================================================================
# Localhost balance / fallback routing
# =============================================================================
# Default stance:
#   Local-first. Cloud fallback is disabled by default for real/private data.
#
# To enable balanced mode later, the UI should request explicit user consent
# before sending document-derived prompts to a cloud provider.
#
# Recommended manual switch for demo/non-private data:
#   HOME_RAG_LLM_FALLBACK_ENABLED=true

HOME_RAG_LOCAL_PROFILE=balanced
HOME_RAG_DATA_MODE=real

HOME_RAG_LLM_FALLBACK_ENABLED=false
HOME_RAG_LLM_FALLBACK_API_BASE=https://openrouter.ai/api/v1
HOME_RAG_LLM_FALLBACK_MODEL=openai/gpt-4o-mini

# Give the local model enough time before opening fallback/circuit-breaker.
HOME_RAG_LLM_LOCAL_SOFT_TIMEOUT_SEC=15
HOME_RAG_LLM_LOCAL_HARD_TIMEOUT_SEC=45


# =============================================================================
# Advisory cloud model registry
# =============================================================================
# These CLOUD_* values are advisory seed values for a future provider/router.
# They are not necessarily consumed by runtime unless app code explicitly uses them.
# Re-check provider model pages/pricing before production load.

CLOUD_FAST_MODEL=openai/gpt-4o-mini
CLOUD_CODING_MODEL=qwen/qwen-2.5-coder-32b-instruct
CLOUD_REASONING_MODEL=deepseek/deepseek-r1-distill-qwen-32b
CLOUD_GRAPH_MODEL=qwen/qwen3.5-35b-a3b
CLOUD_DOCUMENT_MODEL=google/gemma-4-31b-it

DEEPSEEK_MODEL=deepseek-reasoner
DEEPSEEK_API_BASE=https://api.deepseek.com/v1


# =============================================================================
# Embeddings
# =============================================================================

EMBED_MODEL=perplexity/pplx-embed-v1-0.6b
EMBED_DIMENSIONS=1024
EMBED_API_BASE=https://openrouter.ai/api/v1
EMBED_REQUEST_TIMEOUT=60
EMBED_CONNECT_TIMEOUT_SEC=10.0
EMBED_BATCH_SIZE=32
EMBED_NUM_WORKERS=4
EMBED_MAX_RETRIES=2


# =============================================================================
# SSR — local LLM for Self-Reflective Retrieval
# =============================================================================

SSR_LLM_API_BASE=http://127.0.0.1:8080/v1
SSR_LLM_MODEL=gemma-4-26b-a4b-it-q4-0
ENABLE_SSR_LLM_PROFILING=true
SSR_LLM_PROFILE_LOG_DIR=logs/ssr_llm_profiles


# =============================================================================
# Indexing
# =============================================================================

CHUNK_SIZE=1500
CHUNK_OVERLAP=50
SPLIT_STRATEGY=sentence_splitter
WINDOW_SIZE=2
DOC_LOAD_NUM_WORKERS=4

# Keep enrichment off by default to avoid unexpected cloud calls/cost.
ENABLE_METADATA_ENRICHMENT=false
ENABLE_DOCUMENT_SUMMARIES=false


# =============================================================================
# Retrieval
# =============================================================================
# Quality-first profile for the new AI workstation.
# This is the recommended default for home_rag learning/docs analysis.

RAG_PROFILE=quality
RETRIEVAL_MODE=hybrid
SIMILARITY_TOP_K=10
ENABLE_RERANKER=true
RERANK_TOP_N=4

# Fast/demo alternative, if needed:
# RAG_PROFILE=fast
# RETRIEVAL_MODE=vector_only
# SIMILARITY_TOP_K=8
# ENABLE_RERANKER=false
# RERANK_TOP_N=3


# =============================================================================
# Cache, FAQ & summaries
# =============================================================================

COLLECTION_NAME=home-rag_v2
SUMMARY_COLLECTION_NAME=home_rag_summaries
QUERY_ENGINE_CACHE_SIZE=32
QUERY_ENGINE_TTL_SEC=1800
ENABLE_FAQ_CACHE=false
FAQ_MIN_SCORE=0.9


# =============================================================================
# Autonomous Trigger Orchestrator
# =============================================================================

CURSOR_TRIGGER_STARTED_STALL_TIMEOUT_MS=0
CURSOR_TRIGGER_EXIT_ON_SUBSTANTIVE_PROOF=1

# =============================================================================
# Obsidian Export
# =============================================================================

OBSIDIAN_VAULT_NAME=data
OBSIDIAN_VAULT_SUBDIR=data

# SmartKonspekt clean-run result (2026-06-09): single-compose is not viable on
# qwen/qwen3.6-27b with the current prompt shape. After merge max_tokens fix,
# compose used 14328 prompt tokens and hit the model/server total context cap:
# completion_tokens=2056, total_tokens=16384, finish_reason=length, truncated=1.
# Keep 8192 only as a ceiling for smaller/section-level prompts; do not expect
# 8192 output tokens when compose input already consumes most of the context.
OBSIDIAN_EXPORT_COMPOSE_MAX_TOKENS=8192
OBSIDIAN_EXPORT_LLM_TIMEOUT_SEC=600



ENABLE_OTEL_TRACING=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:3000/api/public/otel/v1/traces
OTEL_SERVICE_NAME=home-rag

# LANGFUSE_TRACE_EXPORT_ENABLED=false
