# =============================================================================
# home-rag secrets configuration (.env — NOT tracked in git)
# Copy this file to .env and fill in your secrets:   cp .env.example .env
#
# Non-secret settings (models, URLs, chunk sizes, etc.) live in config.env
# which IS tracked in git. You only need .env for API keys and tokens.
# =============================================================================

# === REQUIRED secret ===
OPENAI_API_KEY=your-key-here          # OpenAI / OpenRouter API key

# === Optional secrets (uncomment when needed) ===
# HOME_RAG_API_KEY=                   # protects REST endpoints with X-API-Key header
# DEEPSEEK_API_KEY=                   # DeepSeek API key
# TELEGRAM_BOT_TOKEN=                 # Telegram bot
# CURSOR_API_KEY=                     # Cursor SDK trigger


# CURSOR_TRIGGER_EXIT_ON_SUBSTANTIVE_PROOF=1   # default 1: exit trigger when proof file is substantive (don't wait for full Agent.prompt)
# CURSOR_TRIGGER_METRICS_PATH=archive/team_artifacts/_metrics/cursor_agent_trigger.jsonl
# WORKFLOW_TRIGGER_RETRIES=2                  # workflow.py --loop: retries for trigger rc=2/3
# WORKFLOW_ORCH_STEP_WATCH_TIMEOUT=1800       # per-step watch in ready_orch (seconds)
# Lock: archive/team_artifacts/_locks/workflow-loop.lock (auto, one --loop per repo)

EMBED_MODEL=perplexity/pplx-embed-v1-0.6b   # embedding model name
EMBED_DIMENSIONS=1024                # expected/requested embedding vector size (0 = provider default)
# EVAL_JUDGE_LLM=                     # separate model for eval judge (defaults to LLM_MODEL)
# REWRITE_MODEL=                      # model for query rewriting (defaults to LLM_MODEL)
# CLASSIFIER_MODEL=                   # model for intent classification (defaults to LLM_MODEL)
# INGESTION_MODEL=                    # metadata enrichment & ingest text fallback LLM (defaults to LLM_MODEL)
# EVALUATE_MODEL=                     # inline-quiz free-text scoring LLM (defaults to LLM_MODEL)
# QUIZ_LEARNING_MODE_DEFAULT=default  # default | understand_topic | exam_prep | solve_homework


# TUTOR & QUIZ LLM
LLM_API_BASE=http://127.0.0.1:1234/v1  # OpenAI-compatible base URL for LLM_MODEL / QUIZ_LLM_MODEL (LM Studio)
LLM_MODEL=qwen2.5-coder-7b-instruct
# QUIZ_LLM_MODEL=                     # model for quiz generation (defaults to LLM_MODEL)
# GRAPH_LLM_API_BASE=http://127.0.0.1:1234/v1  # local graph/concept model endpoint
# GRAPH_MODEL=qwen/qwen3.6-27b         # concept extraction, prerequisite chains, graph/tutor orchestration
LLAMAINDEX_METADATA_FALLBACK_MODEL=gpt-4o-mini  # llama-index metadata alias only; real requests still use LLM_MODEL

# Localhost balance: primary-chat routing profile.
# Choose one of the three blocks below; uncomment the one that matches your setup.

# --- BALANCED (default) ---
# Local LLM first; falls back to cloud when local CB/timeout policy allows it.
HOME_RAG_LOCAL_PROFILE=balanced
HOME_RAG_DATA_MODE=real               # real | demo
HOME_RAG_LLM_FALLBACK_ENABLED=true
# HOME_RAG_LLM_CLOUD_CONSENT=false    # set true only when real-data primary chat may use cloud fallback
HOME_RAG_LLM_FALLBACK_API_BASE=https://openrouter.ai/api/v1
HOME_RAG_LLM_FALLBACK_MODEL=openai/gpt-4o-mini
HOME_RAG_LLM_LOCAL_SOFT_TIMEOUT_SEC=8
HOME_RAG_LLM_LOCAL_HARD_TIMEOUT_SEC=20
SSR_LLM_MODEL=qwen2.5-coder-7b-instruct  # explicit SSR model — avoids "SSR effective model empty" warning at startup

# --- LOCAL_STRICT (air-gap / privacy) ---
# Never sends primary-chat traffic to cloud. Requires local LLM reachable at LLM_API_BASE.
# HOME_RAG_LOCAL_PROFILE=local_strict
# HOME_RAG_DATA_MODE=real
# HOME_RAG_LLM_FALLBACK_ENABLED=false
# HOME_RAG_LLM_FALLBACK_API_BASE=
# HOME_RAG_LLM_FALLBACK_MODEL=
# HOME_RAG_LLM_LOCAL_SOFT_TIMEOUT_SEC=8
# HOME_RAG_LLM_LOCAL_HARD_TIMEOUT_SEC=20

# --- CLOUD_FAST (cloud primary) ---
# Primary chat goes directly to cloud; data/index/SRS stay local.
# For HOME_RAG_DATA_MODE=real this also requires HOME_RAG_LLM_CLOUD_CONSENT=true.
# Requires OPENAI_API_KEY (or OpenRouter key in OPENAI_API_KEY) and a cloud model id in LLM_MODEL or HOME_RAG_LLM_FALLBACK_MODEL.
# HOME_RAG_LOCAL_PROFILE=cloud_fast
# HOME_RAG_DATA_MODE=real
# HOME_RAG_LLM_CLOUD_CONSENT=true
# HOME_RAG_LLM_FALLBACK_ENABLED=true
# HOME_RAG_LLM_FALLBACK_API_BASE=https://openrouter.ai/api/v1
# HOME_RAG_LLM_FALLBACK_MODEL=openai/gpt-4o-mini
# HOME_RAG_LLM_LOCAL_SOFT_TIMEOUT_SEC=8
# HOME_RAG_LLM_LOCAL_HARD_TIMEOUT_SEC=20

# DEEPSEEK
# DEEPSEEK_API_KEY=                  # API key for scripts/deepseek_agent_trigger.ts (not logged by workflow.py)
DEEPSEEK_MODEL=deepseek-reasoner
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
# DEEPSEEK_TRIGGER_HEARTBEAT_MS=30000
# DEEPSEEK_TRIGGER_STARTED_STALL_TIMEOUT_MS=480000
# DEEPSEEK_TRIGGER_METRICS_PATH=archive/team_artifacts/_metrics/deepseek_agent_trigger.jsonl

# SSR (подсказка учебного маршрута): персонализация короткой причины — отдельный endpoint/модель от основного чата.
# SSR_LLM_API_BASE=http://127.0.0.1:1234  # LM Studio default port (change if you run on a custom port)
# Если loopback-порт недоступен ~0.6 с, SSR по умолчанию падает явно, без тихого main/cloud fallback.
# SSR_ALLOW_MAIN_LLM_FALLBACK=false       # set true only if SSR may reuse primary chat LLM.
# Путь /v1 добавляется автоматически, если в URL нет пути (как у LM Studio).
# Чтобы ходить в тот же API, что и основной чат: SSR_LLM_API_BASE=
# SSR_LLM_API_KEY=                    # по умолчанию OPENAI_API_KEY; на localhost без ключа — заглушка lm-studio
# SSR_LLM_MODEL=                      # по умолчанию LLM_MODEL; для LM Studio — id загруженной модели
# ENABLE_SSR_LLM_PROFILING=true       # JSONL-профили SSR короткой причины (latency, model, outcome)
# SSR_LLM_PROFILE_LOG_DIR=logs/ssr_llm_profiles
# Сводка: python scripts/summarize_ssr_llm_profiles.py [--json] [--last-files N]
#
# Local LLM diagnostics & circuit breaker:
# LLM_LOCAL_WARMUP=true              # probe SSR endpoint at startup (default true); set false to skip
# LLM_LOCAL_CB_FAILURES=3            # consecutive failures to open circuit (default 3)
# LLM_LOCAL_CB_RESET_SEC=60          # seconds before circuit auto-half-opens (default 60)
# LLM_LOCAL_CB_WINDOW_SEC=30         # failure counting window in seconds (default 30)
# Триаж ошибок: python scripts/llm_errors_today.py [--date YYYY-MM-DD] [--last N] [--all]
#
# AI-агент (agentic loop + tools) — см. docs/agent_roadmap.md.
# Всё выключено по умолчанию: главный /ask-flow не меняется, пока AGENT_ENABLED=false.
# AGENT_ENABLED=false                 # включает ветку query_mode=agent в answer_question
# AGENT_TOOL_CALL_MODE=json           # json | native | auto (native tools API vs JSON-decision)
# AGENT_MAX_STEPS=6                   # ресурсный stop: макс. шагов агентного цикла
# AGENT_MAX_RUN_TOKENS=60000          # ресурсный stop: бюджет токенов на run (0 = без лимита)
# AGENT_MAX_RUN_COST_USD=0            # ресурсный stop: бюджет стоимости на run в USD (0 = без лимита)
# AGENT_MAX_RUN_SECONDS=120           # ресурсный stop: макс. wall-time на run в секундах (0 = без лимита)

# --- LOCAL_OLLAMA example (OpenAI-compatible local endpoint) ---
# OPENAI_API_KEY=local
# LLM_API_BASE=http://127.0.0.1:11434/v1
# EMBED_API_BASE=http://127.0.0.1:11434/v1
# LLM_MODEL=qwen2.5:7b-instruct
# EMBED_MODEL=nomic-embed-text
# EMBED_DIMENSIONS=768
# Requires: `ollama serve`, `ollama pull qwen2.5:7b-instruct`, `ollama pull nomic-embed-text`

# --- HYBRID: cloud LLM (OpenRouter) + local embeddings (Ollama) ---
# Чат/классификация/rewrite — в облаке; эмбеддинги (индексация + запросы) — локально на Ollama.
# EMBED_API_BASE едино для индексации и запросов — менять только его при смене провайдера.
# Перед запуском: `ollama serve` и `ollama pull nomic-embed-text`.
# OPENAI_API_KEY=<openrouter_key>
# LLM_API_BASE=https://openrouter.ai/api/v1
# LLM_MODEL=gpt-4o-mini
# EMBED_API_BASE=http://127.0.0.1:11434/v1
# EMBED_MODEL=nomic-embed-text
# EMBED_DIMENSIONS=768
# На слабом CPU увеличьте таймауты (индексация дольше, но без обрыва):
# EMBED_REQUEST_TIMEOUT=300
# EMBED_CONNECT_TIMEOUT_SEC=30.0
# EMBED_BATCH_SIZE=32
# Снизить нагрузку при полном reindex (без LLM в ingestion):
# ENABLE_METADATA_ENRICHMENT=false
# ENABLE_DOCUMENT_SUMMARIES=false

# === Embeddings ===
# EMBED_MODEL и EMBED_API_BASE едины для индексации и запросов — размерность векторов должна совпадать.
# Сменить провайдера можно только через EMBED_API_BASE (Ollama или OpenRouter — для всего).
#   ollama serve && ollama pull nomic-embed-text && ollama cp nomic-embed-text text-embedding-3-small

# (Ollama, бесплатно):
# EMBED_API_BASE=http://127.0.0.1:11434/v1
# EMBED_REQUEST_TIMEOUT=300
# EMBED_CONNECT_TIMEOUT_SEC=30.0
# EMBED_BATCH_SIZE=32
# EMBED_NUM_WORKERS=4

# (OpenRouter, быстро ~$0.02/1M токенов):
# EMBED_API_BASE=https://openrouter.ai/api/v1
# EMBED_DIMENSIONS=1024
# EMBED_REQUEST_TIMEOUT=60
# EMBED_CONNECT_TIMEOUT_SEC=10.0
# EMBED_BATCH_SIZE=32
# EMBED_NUM_WORKERS=4

# === LLM reliability ===
# EMBED_MAX_RETRIES=2
# LLM_MAX_RETRIES=2
# LLM_REQUEST_TIMEOUT=60             # read timeout for LLM API (seconds)
# LLM_CONNECT_TIMEOUT_SEC=10.0       # connect timeout for LLM API (seconds)
# ENABLE_LLM_FALLBACK=false          # try fallback model after retries exhausted
# LLM_FALLBACK_MODEL=                # fallback model name
# ENABLE_ASYNC_QUALITY_JUDGE=false   # background judge after /ask (expensive)
# ASYNC_QUALITY_JUDGE_SAMPLE_RATE=0.1

# --- Runtime data layout (optional; defaults = repo root) ---
# HOME_RAG_HOME задаёт корень данных. Используется:
#   - docker-compose.yml для volume mounts
#   - app/config.py для дефолтов DATA_DIR/CHROMA_DIR/LOG_DIR
#   - ingest.py при переиндексации с хоста
# Пример: HOME_RAG_HOME=D:/AI/app  → данные в D:\AI\app\{data,chroma_db,logs}
# HOME_RAG_HOME=/srv/home-rag
# HOME_RAG_DATA_DIR=/srv/home-rag/data     # весь data/: корпус + кэш + state
# HOME_RAG_INDEX_DIR=/srv/home-rag/index   # chroma_db (+ TODO: реестр/мета)
# HOME_RAG_LOG_DIR=/srv/home-rag/logs

# === Observability paths ===
# Логи API: на Windows по умолчанию без ротации (rename → WinError 32, если файл открыт ещё где-то).
# HOME_RAG_LOG_ROTATE=true          # Windows: включить RotatingFileHandler обратно
# HOME_RAG_NO_LOG_ROTATE=true       # любая ОС: только logs/app.log без ротации
# HOME_RAG_E2E_NO_LOG_ROTATE=1      # e2e Playwright / совместимость — то же без ротации
# LLM_COST_LOG_DIR=logs/cost_logs
# METRICS_STORE_PATH=logs/metrics_store.jsonl
# METRICS_DASHBOARD_DB_PATH=logs/metrics_dashboard.db
# FEEDBACK_PATH=logs/feedback.jsonl
# HISTORY_PATH=logs/history.jsonl

# === Rate limiting ===
# API_RATE_LIMIT_PER_MINUTE=0        # 0 = disabled

# === Indexing ===
CHUNK_SIZE=700
CHUNK_OVERLAP=100
SPLIT_STRATEGY=sentence_window       # sentence_window | sentence_splitter
WINDOW_SIZE=2
DOC_LOAD_NUM_WORKERS=4              # PDF/HTML/DOCX extraction threads; try 8-12 on strong CPUs
# INGEST_DOCLING_ENABLED=false       # US-2.3: Docling для сканов/изображений в data/ (нужен пакет docling)
# INGEST_DOCLING_MIN_NATIVE_TEXT_CHARS=48   # PDF ниже порога → Docling

# === Retrieval ===
RAG_PROFILE=fast                     # fast | quality
RETRIEVAL_MODE=vector_only           # vector_only | hybrid | bm25_only | doc_then_chunk
SIMILARITY_TOP_K=10
ENABLE_RERANKER=true
RERANK_TOP_N=4
# RERANK_MODEL=BAAI/bge-reranker-base
# DOC_TOP_K=5

# === Cache, FAQ and summaries ===
COLLECTION_NAME=home_rag
SUMMARY_COLLECTION_NAME=home_rag_summaries
QUERY_ENGINE_CACHE_SIZE=32
QUERY_ENGINE_TTL_SEC=1800
ENABLE_FAQ_CACHE=false
FAQ_MIN_SCORE=0.9
# FAQ_MEMORY_COLLECTION_NAME=home_rag_faq
# FAQ_DEDUP_MIN_SCORE=0.92
ENABLE_METADATA_ENRICHMENT=true
ENABLE_DOCUMENT_SUMMARIES=true
# ENABLE_PARTIAL_REINDEX=true

# === US-3.6 / MoT#2: two-stage answer (early extractive vs full LLM) ===
# ENABLE_TWO_STAGE_ANSWER_PATH=false
# TWO_STAGE_EARLY_EXIT_MIN_SCORE=0.55
# TWO_STAGE_EARLY_EXIT_MIN_NODES=2
# TWO_STAGE_EXTRACTIVE_MAX_CHARS=2400
# REQUEST_CONTEXT_TOKEN_BUDGET_SOFT=1000000

# === Guardrails ===
# GUARDRAILS_MAX_QUESTION_LENGTH=2000
# GUARDRAILS_BLOCK_ON_PROMPT_INJECTION=true
# GUARDRAILS_REQUIRE_SOURCES=true
# GUARDRAILS_FALLBACK_ON_EMPTY_ANSWER=true
# GUARDRAILS_FALLBACK_ON_MISSING_SOURCES=true
# GUARDRAILS_FALLBACK_ON_SUSPICIOUS_OUTPUT=true
# GUARDRAILS_FALLBACK_ON_PII_DETECTED=true

# === Multi-turn / condense ===
# ENABLE_CONDENSE=true
# CONDENSE_HISTORY_WINDOW=8
# CONDENSE_HISTORY_WINDOW_TUTOR=16
# SESSION_HISTORY_MAX_MESSAGES=256

# === Tutor ===
# ENABLE_TUTOR_INLINE_QUIZ=true
# TUTOR_INLINE_QUIZ_SEPARATE_LLM_CALL=true
# ENABLE_TUTOR_AUTO_QUIZ_LOOP=true
# ENABLE_TUTOR_PEDAGOGICAL_ORCHESTRATOR=false

# === Query rewrite and classification ===
# ENABLE_REWRITE=false
# ENABLE_CLASSIFIER=false
# ENABLE_SELF_CORRECTION=false

# === Graph-augmented retrieval ===
# ENABLE_GRAPH_AUGMENTED_RETRIEVAL=false
# GRAPH_AUGMENT_MAX_EXTRA_DOCS=4
# GRAPH_EXPAND_MAX_HOPS=3
# ENABLE_RETRIEVAL_SELF_CORRECTION=false
# RETRIEVAL_SELF_CORRECTION_MIN_SCORE=0.22

# === SLO / alerting ===
# SLO_MAX_FALLBACK_RATE=
# SLO_MIN_SOURCE_COVERAGE=
# SLO_MAX_P95_LATENCY_MS=
# SLO_MAX_AVG_COST_USD=
# SLO_MIN_JUDGE_SCORE=
# SLO_MAX_LEARNER_REHYDRATED_RATE=
# SLO_ANOMALY_RECENT_WINDOW=50
# SLO_ANOMALY_SIGMA=2.0
# ALERT_WEBHOOK_URL=

# === OpenTelemetry / Langfuse trace export ===
# Локально без Langfuse/OTLP collector — держите false, иначе retry на недоступный endpoint.
# ENABLE_OTEL_TRACING=false
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_HEADERS=
# OTEL_SERVICE_NAME=home-rag
# LANGFUSE_TRACE_EXPORT_ENABLED=false
# LANGFUSE_HOST=http://localhost:3000
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# When LANGFUSE_TRACE_EXPORT_ENABLED=true and OTEL endpoint is unset, LANGFUSE_HOST
# resolves to /api/public/otel/v1/traces with Basic auth from public/secret keys.

# === Telegram bot (optional) ===
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_DAILY_REMINDER_CHAT_ID=
# TELEGRAM_DAILY_REMINDER_HOUR=9

# === Offline mode ===
# OFFLINE_MODE=false
# OFFLINE_PROBE_LLM_ENDPOINT=true

# === Streamlit UI ===
# UI_API_BASE_URL=http://127.0.0.1:8000
# SHOW_TUTOR_DEV_TOOLS=false
# E30 Course Cockpit v2: single-pane режим (вкладка «Темы» + активный курс → кнопка входа в кабину)
# RAG_COURSE_COCKPIT_V2=false

# === Playwright / e2e stack (optional) ===
# Скрипт scripts/e2e_run_stack.mjs сам выставляет HOME_RAG_E2E_OFFLINE=1 для smoke без OPENAI_API_KEY.
# Вручную: включает заглушку POST /flashcards/generate (детерминированные карточки из текста источника).
# HOME_RAG_E2E_OFFLINE=1

# === Autonomous pipeline / close_package team artifacts (optional) ===
# Управляет ClosePackageArgs при автоматическом закрытии из scripts/run_autonomous.py:
# HOME_RAG_TEAM_ARTIFACTS_STRICT=1   — предупреждения validate_team_artifact считаются ошибкой закрытия
# HOME_RAG_SKIP_TEAM_ARTIFACTS_GATE=1 — не вызывать проверку артефактов оркестратора перед закрытием

# CORS_ORIGINS=http://127.0.0.1:8501,http://localhost:8501

# ── Trigger configuration ──
# CURSOR_API_KEY=                   # Cursor SDK trigger
# DEEPSEEK_API_KEY=                 # DeepSeek API + TUI triggers
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_TUI_MAX_INPUT_TOKENS=120000
# DEEPSEEK_TUI_WARN_INPUT_TOKENS=80000
# DEEPSEEK_TUI_TIMEOUT_MS=900000
# TRIGGER_STRATEGY=                 # auto (default) | direct_cursor | direct_deepseek_tui | manual_handoff
