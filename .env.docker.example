# Пример .env для docker compose (скопируйте нужные строки в .env)
# Полный шаблон: .env.example
#
# Запуск:
#   copy .env.example .env
#   # замените LLM/SSR URL на host.docker.internal (см. ниже)
#   docker compose up --build
#
# Или без правки .env (мост 127.0.0.1:1234 → хост):
#   docker compose -f docker-compose.yml -f docker-compose.lmstudio.yml up --build

OPENAI_API_KEY=your-key-here

# LM Studio на хосте (НЕ 127.0.0.1 — из контейнера это не хост)
LLM_API_BASE=http://host.docker.internal:1234/v1
LLM_MODEL=<id-модели-в-lm-studio>

# SSR (короткая причина шага) — тот же LM Studio на хосте
SSR_LLM_API_BASE=http://host.docker.internal:1234
# SSR_LLM_MODEL=<id-модели>

# Ollama на хосте (пример)
# LLM_API_BASE=http://host.docker.internal:11434/v1
# EMBED_API_BASE=http://host.docker.internal:11434/v1
# LLM_MODEL=qwen2.5:7b-instruct
# EMBED_MODEL=nomic-embed-text

# Streamlit в контейнере ходит в API того же контейнера — менять не нужно
# UI_API_BASE_URL=http://127.0.0.1:8000
