# Hugging Face Spaces — demo (скопировать в Secrets или .env на Space)
# См. deploy/hf-spaces/README.md

OPENAI_API_BASE=https://openrouter.ai/api/v1
# OPENAI_API_KEY=<задать в HF Settings → Secrets>
LLM_MODEL=mistralai/mistral-7b-instruct:free
EMBED_MODEL=perplexity/pplx-embed-v1-0.6b
EMBED_DIMENSIONS=1024

# Отключить тяжёлые фичи для cold start
ENABLE_METADATA_ENRICHMENT=false
ENABLE_DOCUMENT_SUMMARIES=false
ENABLE_RERANKER=false

# Demo: не требовать API key для UI (опционально задать для REST)
# HOME_RAG_API_KEY=
